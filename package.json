{
  "name": "markdown-notes",
  "version": "0.1.0",
  "description": "A markdown-first note-taking desktop app",
  "main": "./out/main/index.js",
  "author": "",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:mac": "electron-vite build && electron-builder --mac --publish=never",
    "build:win": "electron-vite build && electron-builder --win --publish=never",
    "build:all": "electron-vite build && electron-builder --mac --win --publish=never"
  },
  "dependencies": {
    "@milkdown/crepe": "^7.5.0",
    "@milkdown/utils": "^7.5.0",
    "@xenova/transformers": "^2.17.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.markdownnotes.app",
    "productName": "Markdown Notes",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "npmRebuild": false,
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["arm64"] }
      ],
      "icon": "build/icon.icns",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png",
      "extraFiles": [
        {
          "from": "node_modules/onnxruntime-node/bin/napi-v3/win32/${arch}/",
          "to": "resources/app.asar.unpacked/node_modules/onnxruntime-node/bin/napi-v3/win32/${arch}/",
          "filter": ["*.dll"]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
